# 基于Transformer的股票情绪预测系统 - 环境配置

# 应用配置
DEBUG=True

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=stock_sentiment

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# 模型配置
MODEL_NAME=hfl/chinese-bert-wwm-ext
MODEL_MAX_LENGTH=128
MODEL_CACHE_DIR=./data/models

# 爬虫配置
CRAWLER_DELAY_MIN=3.0
CRAWLER_DELAY_MAX=8.0
CRAWLER_MAX_RETRY=3
CRAWLER_TIMEOUT=30

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
